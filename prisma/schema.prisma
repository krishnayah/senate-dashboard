// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique
  hasRequiredRole Boolean  @default(false)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Group {
  id        String    @id @default(cuid())
  name      String    @unique // e.g., "Senate", "EBoard"
  speakers  Speaker[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Speaker {
  id         String      @id @default(cuid())
  name       String
  type       String      @default("guest") // Deprecated: Migration will move this to Groups
  speakCount Int         @default(0)
  groups     Group[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  meetingAttendance  MeetingAttendance[]
  requiredInGroups   MeetingGroup[]       @relation("RequiredMembers")
}

model MeetingGroup {
  id              String    @id @default(cuid())
  name            String
  meetings        Meeting[]
  requiredMembers Speaker[] @relation("RequiredMembers")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Meeting {
  id             String              @id @default(cuid())
  title          String
  date           DateTime            @default(now())
  notes          String?
  meetingGroupId String?
  meetingGroup   MeetingGroup?       @relation(fields: [meetingGroupId], references: [id], onDelete: Cascade)
  attendance     MeetingAttendance[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED
  ABSENT
  OTHER
}

model MeetingAttendance {
  id        String           @id @default(cuid())
  meetingId String
  speakerId String
  meeting   Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker   Speaker          @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())

  @@unique([meetingId, speakerId])
}
